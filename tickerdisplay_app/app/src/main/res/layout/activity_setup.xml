<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:focusableInTouchMode="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="34sp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ticker Display"
                    android:textColor="@color/td_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modernes Kiosk- und Wallpanel für Home Assistant"
                    android:textColor="@color/td_text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_card"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inbetriebnahme"
                android:textColor="@color/td_primary"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/td_text"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:text="Schritt 1" />

            <TextView
                android:id="@+id/step_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/td_text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="8dp"
                android:text="Beschreibung" />

            <LinearLayout
                android:id="@+id/input_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_scan_qr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="QR-Code scannen"
                android:textAllCaps="false"
                android:textColor="@color/td_text"
                android:background="@drawable/bg_button_secondary"
                android:visibility="gone"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/td_warning"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="14dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_card_subtle"
            android:padding="16dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hinweis"
                android:textColor="@color/td_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wenn du ein Display neu anmeldest, kannst du denselben Gerätenamen weiterverwenden oder bewusst eine neue Geräte-ID vergeben. So bleibt Home Assistant übersichtlich."
                android:textColor="@color/td_text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Zurück"
                android:textAllCaps="false"
                android:textColor="@color/td_text"
                android:background="@drawable/bg_button_secondary"
                android:visibility="gone"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Weiter"
                android:textAllCaps="false"
                android:textColor="@color/td_text"
                android:background="@drawable/bg_button_primary" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
