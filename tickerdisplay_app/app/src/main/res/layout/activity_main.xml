<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


    <FrameLayout
        android:id="@+id/native_overlay_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false">

        <FrameLayout
            android:id="@+id/native_alert_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3000000"
            android:visibility="gone"
            android:clickable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <LinearLayout
                    android:id="@+id/native_alert_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:background="@drawable/bg_surface_glow">

                    <TextView
                        android:id="@+id/native_alert_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Alert"
                        android:textColor="#FFFFFFFF"
                        android:textStyle="bold"
                        android:textSize="42sp" />

                    <TextView
                        android:id="@+id/native_alert_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginTop="14dp"
                        android:text="Nachricht"
                        android:textColor="#FFFFFFFF"
                        android:textSize="24sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/native_ticker_bar"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_gravity="bottom"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:background="#E6000000"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/offline_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app_gradient"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_glow"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/offline_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge"
                android:text="Automatische Wiederverbindung"
                android:textColor="@color/td_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="60sp"
                android:layout_marginTop="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ticker Display"
                android:textColor="@color/td_text"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/offline_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Verbindung unterbrochen"
                android:textColor="@color/td_text_secondary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/offline_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Die App versucht automatisch neu zu verbinden."
                android:textColor="@color/td_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="22dp">

                <Button
                    android:id="@+id/btn_offline_reload"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Neu laden"
                    android:textAllCaps="false"
                    android:textColor="@color/td_text"
                    android:background="@drawable/bg_button_primary"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_offline_settings"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Einstellungen"
                    android:textAllCaps="false"
                    android:textColor="@color/td_text"
                    android:background="@drawable/bg_button_secondary"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Menü weiterhin erreichbar: Rand-Wischgeste, 3-Finger-Tap oder 5x Lautstärke runter."
                android:textColor="@color/td_text_muted"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="14dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
